# SENG 468 Final Project — sample environment file.
# Copy to .env; defaults in docker-compose.yml work as-is for local dev.

# ─── Embedding model (must run locally — no API-based models per spec) ───
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ─── Redis cache TTL for query embeddings (seconds) ───
CACHE_TTL=300

# ─── Optional overrides ─────────────────────────────────────────────────
# POSTGRES_DB=userauth
# POSTGRES_USER=userauth
# MINIO_ROOT_USER=pdfstore
# MINIO_BUCKET=user-pdfs
# RABBITMQ_USER=guest
# RABBITMQ_PASSWORD=guest

# Secrets are file-mounted from ./secrets/  (NOT here).
#   secrets/userauth-pass  → Postgres password
#   secrets/pdfstore-pass  → MinIO root password
#   secrets/jwt-key        → JWT signing key
